#!/usr/bin/env ruby
# frozen_string_literal: true

lib = File.expand_path("#{File.dirname(__FILE__)}/../lib")
$LOAD_PATH.unshift(lib) if File.directory?(lib) && !$LOAD_PATH.include?(lib)

require 'bugspots'
require 'optparse'
require 'rainbow'
require 'rainbow/ext/string'

ARGV << '--help' if ARGV.empty?

def validate_cyclomatic_options!(options)
  {
    '-d' => options[:depth_option_used],
    '-w' => options[:words_option_used],
    '-r' => options[:regex_option_used],
    '--display-timestamps' => options[:display_timestamps_option_used]
  }.each do |flag, used|
    raise ArgumentError, "option #{flag} is not available with -c" if used
  end
end

def validate_both_options!(options)
  {
    '-d' => options[:depth_option_used],
    '-w' => options[:words_option_used],
    '-r' => options[:regex_option_used],
    '--display-timestamps' => options[:display_timestamps_option_used],
    '-c' => options[:cyclomatic_complexity]
  }.each do |flag, used|
    raise ArgumentError, "option #{flag} is not available with --both" if used
  end
end

options = {}
# rubocop:disable Metrics/BlockLength
OptionParser.new do |opts|
  opts.banner = <<~TEXT
    Usage: bugspots /path/to/git/repo [options]

    Modes:
      default  Bug-fix hotspot scoring
      -c       File-level cyclomatic complexity for Go / TypeScript
      --both   Combined score: hotspot_score * cyclomatic_score
  TEXT

  opts.on('--both', 'report combined hotspot and cyclomatic scores by file') do
    options[:both] = true
  end

  opts.on('-c', '--cyclomatic-complexity',
          'report file-level cyclomatic complexity by file') do
    options[:cyclomatic_complexity] = true
  end

  # Option: Set Branch
  opts.on('-b', '--branch [name]', 'branch to crawl') do |b|
    options[:branch] = b.to_s
  end

  # Option: Set Depth
  opts.on('-d', '--depth [depth]', 'depth of log crawl (integer)') do |d|
    options[:depth] = d.to_i
    options[:depth_option_used] = true
  end

  # Option: Set Bugfix Indicator
  opts.on('-w', '--words ["w1,w2"]', 'bugfix indicator word list, ie: "fixes,closed"') do |words|
    options[:regex] = Regexp.new(words.split(',').join('|'))
    options[:words_option_used] = true
  end

  # Option: Set Bugfix Indicator
  opts.on('-r', '--regex [regex]', Regexp,
          'bugfix indicator regex, ie: "fix(es|ed)?" or "/fixes #(\d+)/i"') do |regex|
    options[:regex] = regex
    options[:regex_option_used] = true
  end

  opts.on('--exclude-path [regex]', Regexp,
          'exclude changed file paths matching the given regex') do |regex|
    options[:exclude_path_regex] = regex
  end

  # Option: Set Timestamp Display
  opts.on('--display-timestamps', 'show timestamps of each identified fix commit') do |_dt|
    options[:display_timestamps] = true
    options[:display_timestamps_option_used] = true
  end

  opts.separator ''
  opts.separator 'Mode constraints:'
  opts.separator '  -c only allows -b and --exclude-path.'
  opts.separator '  --both only allows -b and --exclude-path.'
end.parse!
# rubocop:enable Metrics/BlockLength

# Set main as the default branch
options[:branch] ||= 'main'

puts "Scanning #{ARGV[0]} repo".foreground(:green)

begin
  if options[:both]
    validate_both_options!(options)

    _fixes, hotspots = Bugspots.scan(
      ARGV[0],
      options[:branch],
      nil,
      nil,
      options[:exclude_path_regex]
    )
    complexities = Bugspots.cyclomatic_complexity(
      ARGV[0],
      options[:branch],
      options[:exclude_path_regex]
    )
    combined_scores = Bugspots.combine_scores(hotspots, complexities)

    puts "\tFound #{combined_scores.size} files with combined scores:".foreground(:yellow)
    puts
    puts "\tCombined Scores:".foreground(:green).underline
    combined_scores.each do |result|
      puts "\t\t#{result.combined_score}".foreground(:red) \
           + " (hotspot: #{result.hotspot_score}, cyclomatic: #{result.cyclomatic_score}, " \
           + "functions: #{result.function_count})".foreground(:yellow) \
           + " - #{result.file}".foreground(:yellow)
    end
  elsif options[:cyclomatic_complexity]
    validate_cyclomatic_options!(options)

    complexities = Bugspots.cyclomatic_complexity(
      ARGV[0],
      options[:branch],
      options[:exclude_path_regex]
    )

    puts "\tFound #{complexities.size} files with cyclomatic complexity:".foreground(:yellow)
    puts
    puts "\tCyclomatic Complexity:".foreground(:green).underline
    complexities.each do |complexity|
      puts "\t\t#{complexity.score} (#{complexity.function_count} functions)".foreground(:red) +
           " - #{complexity.file}".foreground(:yellow)
    end
  else
    fixes, spots = Bugspots.scan(
      ARGV[0],
      options[:branch],
      options[:depth],
      options[:regex],
      options[:exclude_path_regex]
    )

    puts "\tFound #{fixes.size} bugfix commits, with #{spots.size} hotspots:".foreground(:yellow)
    puts

    puts "\tFixes:".foreground(:green).underline
    fixes.each do |fix|
      message = String.new("\t\t- ")
      message << "#{fix.date} " if options[:display_timestamps]
      message << fix.message.to_s
      puts message.foreground(:yellow)
    end

    puts "\n"
    puts "\tHotspots:".foreground(:green).underline
    spots.each do |spot|
      puts "\t\t#{spot.score}".foreground(:red) + " - #{spot.file}".foreground(:yellow)
    end
  end
rescue ArgumentError => e
  warn e.message
  exit 1
rescue Rugged::RepositoryError
  error_message = 'Invalid Git repository - please run from or specify the '\
                  'full path to the root of the project.'
  warn error_message.foreground(:red)
  exit 1
end
